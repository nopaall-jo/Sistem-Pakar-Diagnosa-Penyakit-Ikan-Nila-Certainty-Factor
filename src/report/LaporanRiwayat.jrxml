	<queryString>
		<![CDATA[SELECT 
    d.id_diagnosa, 
    d.tanggal_diagnosa, 
    d.kode_sampel, 
    p.nama_penyakit, 
    d.confidence 
FROM tbl_diagnosa d 
LEFT JOIN tbl_penyakit p ON d.hasil_penyakit = p.kode_penyakit 
ORDER BY d.id_diagnosa DESC]]>
	</queryString>
