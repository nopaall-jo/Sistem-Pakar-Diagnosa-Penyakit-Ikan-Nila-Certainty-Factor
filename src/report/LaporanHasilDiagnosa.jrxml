	<parameter name="ADMIN" class="java.lang.String"/>
	<parameter name="ID_DIAGNOSA" class="java.lang.String"/>
	<parameter name="KEMUNGKINAN_LAIN" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT DISTINCT
    d.id_diagnosa, 
    d.kode_sampel, 
    d.tanggal_diagnosa, 
    d.confidence,
    p.nama_penyakit, 
    p.deskripsi, 
    p.solusi, 
    p.pencegahan,
    g.kode_gejala, 
    g.nama_gejala,
    dd.kondisi_gejala
FROM tbl_diagnosa d
JOIN tbl_penyakit p ON d.hasil_penyakit = p.kode_penyakit
JOIN tbl_diagnosa_detail dd ON d.id_diagnosa = dd.id_diagnosa
JOIN tbl_gejala g ON dd.kode_gejala = g.kode_gejala
WHERE d.id_diagnosa = $P{ID_DIAGNOSA}]]>
	</queryString>
