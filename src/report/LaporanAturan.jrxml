	<parameter name="ADMIN" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT 
    a.id_aturan, 
    a.kode_penyakit, 
    p.nama_penyakit, 
    a.kode_gejala, 
    g.nama_gejala, 
    a.nilai_mb, 
    a.nilai_md 
FROM tbl_aturan a 
JOIN tbl_penyakit p ON a.kode_penyakit = p.kode_penyakit 
JOIN tbl_gejala g ON a.kode_gejala = g.kode_gejala]]>
	</queryString>
